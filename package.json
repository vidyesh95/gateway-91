{
	"name": "gateway-91",
	"version": "0.1.0",
	"private": true,
	"description": "Country-restricted Telegram group gatekeeper bot — verifies phone country code (+91 India) and GPS location before approving join requests. Blocks outsiders. Cloudflare Workers + grammY.",
	"keywords": [
		"chat-join-request",
		"cloudflare-workers",
		"country-restriction",
		"gatekeeper",
		"geofencing",
		"grammy",
		"india",
		"join-gate",
		"location-verification",
		"members-only",
		"phone-verification",
		"telegram",
		"telegram-bot",
		"typescript"
	],
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"test": "vitest",
		"cf-typegen": "wrangler types",
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check ."
	},
	"dependencies": {
		"grammy": "^1.44.0"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.4",
		"@types/node": "^25.9.3",
		"oxfmt": "^0.55.0",
		"oxlint": "^1.70.0",
		"oxlint-tsgolint": "^0.23.0",
		"typescript": "^5.5.2",
		"vitest": "~3.2.0",
		"wrangler": "^4.101.0"
	}
}
